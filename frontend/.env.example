# Copy this file to .env.local before running locally.
#
# Usage:
#   cp .env.example .env.local
#
# .env.local is gitignored — never commit it.

# ─── Required ────────────────────────────────────────────────────────────────

# URL of the Cloudflare Workers backend.
# Local dev:  http://localhost:8787  (wrangler dev default port)
# Production: https://<your-worker-subdomain>.workers.dev
NEXT_PUBLIC_API_URL=http://localhost:8787
