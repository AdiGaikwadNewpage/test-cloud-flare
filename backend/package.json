{
  "name": "synthire-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy --env=production",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply synthire-prod --local",
    "db:migrate:prod": "wrangler d1 migrations apply synthire-prod --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "mammoth": "^1.8.0",
    "nanoid": "^5.0.0",
    "pdf-parse": "^1.1.1",
    "resend": "^4.0.0",
    "unpdf": "^1.6.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.93.0"
  }
}
