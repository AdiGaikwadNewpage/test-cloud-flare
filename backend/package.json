    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "nanoid": "^5.0.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.6.0",
    "wrangler": "^3.90.0"
